{
  "schemaVersion": 1,
  "id": "thirdpersonmod",
  "version": "${version}",
  "name": "Cinematic Shoulder Camera",
  "description": "A pure client-side cinematic over-the-shoulder camera for third-person back view.",
  "authors": [],
  "contact": {},
  "license": "All-Rights-Reserved",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.thirdpersonmod.ShoulderCameraClient"
    ]
  },
  "mixins": [
    {
      "config": "thirdpersonmod.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "java": ">=25"
  }
}
